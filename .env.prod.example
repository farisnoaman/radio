# Environment Configuration for Multi-Provider RADIO Production
# Copy this file to .env and update values for your environment
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ==============================================================================
# DOMAIN & SECURITY
# ==============================================================================
DOMAIN=https://radius.your-domain.com

# Generate a secure secret: openssl rand -base64 32
TOUGHRADIUS_WEB_SECRET=change-this-to-a-random-secret-min-32-chars

# Database password (min 16 characters recommended)
DB_PASSWORD=change-this-to-a-strong-password

# ==============================================================================
# DATABASE
# ==============================================================================
# PostgreSQL connection settings are in docker-compose.prod.yml
# These can be overridden here if using external PostgreSQL

# TOUGHRADIUS_DB_HOST=your-postgres-host
# TOUGHRADIUS_DB_PORT=5432
# TOUGHRADIUS_DB_NAME=toughradius
# TOUGHRADIUS_DB_USER=toughradius
# TOUGHRADIUS_DB_PASSWD=your-db-password
# TOUGHRADIUS_DB_MAX_CONN=200
# TOUGHRADIUS_DB_IDLE_CONN=20

# ==============================================================================
# REDIS (L2 Cache)
# ==============================================================================
# Redis connection settings are in docker-compose.prod.yml
# These can be overridden here if using external Redis

# TOUGHRADIUS_REDIS_HOST=your-redis-host
# TOUGHRADIUS_REDIS_PORT=6379

# ==============================================================================
# CACHE TUNING
# ==============================================================================
# L1 Cache (Local Memory)
TOUGHRADIUS_CACHE_L1_ENABLED=true
TOUGHRADIUS_CACHE_L1_MAX_ENTRIES=10000

# L2 Cache (Redis)
TOUGHRADIUS_CACHE_L2_ENABLED=true

# Cache TTL (in seconds)
TOUGHRADIUS_CACHE_USER_TTL=30
TOUGHRADIUS_CACHE_NAS_TTL=300
TOUGHRADIUS_CACHE_SESSION_TTL=5
TOUGHRADIUS_CACHE_VOUCHER_TTL=120

# ==============================================================================
# MULTI-TENANT SCALE
# ==============================================================================
TOUGHRADIUS_MULTITENANT_ENABLED=true
TOUGHRADIUS_CACHE_PROVIDER_COUNT=100
TOUGHRADIUS_CACHE_USERS_PER_PROVIDER=5000
TOUGHRADIUS_CACHE_CONCURRENT_PER_PROVIDER=1500

# ==============================================================================
# LOGGING
# ==============================================================================
TOUGHRADIUS_LOGGER_MODE=production
TOUGHRADIUS_SYSTEM_DEBUG=false
