{
  "schemas": [
    {
      "key": "system.Domain",
      "type": "string",
      "default": "https://radius.hayataxi.online",
      "title": "Application Domain",
      "title_i18n": "config.system.domain.title",
      "description": "The base URL for the application (e.g., https://radius.hayataxi.online). Used for generating links and self-referencing.",
      "description_i18n": "config.system.domain.description"
    },
    {
      "key": "web.CacheTTL",
      "type": "int",
      "default": "60",
      "min": 0,
      "max": 3600,
      "title": "Dashboard Cache TTL",
      "title_i18n": "config.web.cache_ttl.title",
      "description": "Dashboard statistics cache TTL in seconds (0=disabled, default 60s). Controls how long dashboard data is cached before refreshing from database.",
      "description_i18n": "config.web.cache_ttl.description"
    },
    {
      "key": "radius.ServerIP",
      "type": "string",
      "default": "",
      "title": "RADIUS Server IP",
      "title_i18n": "config.radius.server_ip.title",
      "description": "The IP address of this RADIUS server that Mikrotik routers should point to (e.g., 192.168.1.100). Used to auto-configure discovered routers.",
      "description_i18n": "config.radius.server_ip.description"
    },
    {
      "key": "radius.EapMethod",
      "type": "string",
      "default": "eap-md5",
      "enum": [
        "eap-md5",
        "eap-mschapv2"
      ],
      "title": "EAP Method",
      "title_i18n": "config.radius.eap_method.title",
      "description": "EAP authentication method",
      "description_i18n": "config.radius.eap_method.description"
    },
    {
      "key": "radius.EapEnabledHandlers",
      "type": "string",
      "default": "*",
      "title": "Enabled EAP Handlers",
      "title_i18n": "config.radius.eap_enabled_handlers.title",
      "description": "Comma-separated list of enabled EAP handler names (e.g., eap-md5,eap-mschapv2). Use * to allow all registered handlers",
      "description_i18n": "config.radius.eap_enabled_handlers.description"
    },
    {
      "key": "radius.IgnorePassword",
      "type": "bool",
      "default": "false",
      "title": "Ignore Password",
      "title_i18n": "config.radius.ignore_password.title",
      "description": "Ignore password check",
      "description_i18n": "config.radius.ignore_password.description"
    },
    {
      "key": "radius.AccountingHistoryDays",
      "type": "int",
      "default": "90",
      "min": 0,
      "title": "Accounting History Days",
      "title_i18n": "config.radius.accounting_history_days.title",
      "description": "Accounting log retention days (0=disabled)",
      "description_i18n": "config.radius.accounting_history_days.description"
    },
    {
      "key": "radius.AcctInterimInterval",
      "type": "int",
      "default": "300",
      "min": 60,
      "max": 3600,
      "title": "Accounting Interim Interval",
      "title_i18n": "config.radius.acct_interim_interval.title",
      "description": "Accounting interim interval in seconds",
      "description_i18n": "config.radius.acct_interim_interval.description"
    },
    {
      "key": "radius.SessionTimeout",
      "type": "int",
      "default": "3600",
      "min": 300,
      "max": 86400,
      "title": "Session Timeout",
      "title_i18n": "config.radius.session_timeout.title",
      "description": "Default session timeout in seconds",
      "description_i18n": "config.radius.session_timeout.description"
    },
    {
      "key": "radius.LogLevel",
      "type": "string",
      "default": "info",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ],
      "title": "Log Level",
      "title_i18n": "config.radius.log_level.title",
      "description": "RADIUS service log level",
      "description_i18n": "config.radius.log_level.description"
    },
    {
      "key": "radius.RejectDelayMaxRejects",
      "type": "int",
      "default": "7",
      "min": 1,
      "max": 1000,
      "title": "Reject Delay Threshold",
      "title_i18n": "config.radius.reject_delay_max_rejects.title",
      "description": "Maximum consecutive rejects before temporary block",
      "description_i18n": "config.radius.reject_delay_max_rejects.description"
    },
    {
      "key": "radius.RejectDelayWindowSeconds",
      "type": "int",
      "default": "10",
      "min": 1,
      "max": 3600,
      "title": "Reject Delay Window",
      "title_i18n": "config.radius.reject_delay_window_seconds.title",
      "description": "Observation window (seconds) for reject counter reset",
      "description_i18n": "config.radius.reject_delay_window_seconds.description"
    },
    {
      "key": "voucher.CleanupEnabled",
      "type": "bool",
      "default": "true",
      "title": "Enable Voucher Cleanup",
      "title_i18n": "config.voucher.cleanup_enabled.title",
      "description": "Enable automatic cleanup of expired vouchers",
      "description_i18n": "config.voucher.cleanup_enabled.description"
    },
    {
      "key": "voucher.CleanupGraceMinutes",
      "type": "int",
      "default": "60",
      "min": 0,
      "max": 10080,
      "title": "Cleanup Grace Period",
      "title_i18n": "config.voucher.cleanup_grace_minutes.title",
      "description": "Minutes to wait after quota exhaustion before marking voucher as expired",
      "description_i18n": "config.voucher.cleanup_grace_minutes.description"
    },
    {
      "key": "voucher.CleanupRetentionDays",
      "type": "int",
      "default": "7",
      "min": 0,
      "max": 365,
      "title": "Voucher Retention Days",
      "title_i18n": "config.voucher.cleanup_retention_days.title",
      "description": "Days to keep expired vouchers before soft-deleting them",
      "description_i18n": "config.voucher.cleanup_retention_days.description"
    },
    {
      "key": "billing.DefaultPricePerGb",
      "type": "string",
      "default": "0.10",
      "title": "Default Price Per GB",
      "title_i18n": "config.billing.default_price_per_gb.title",
      "description": "Default price per GB for postpaid (monthly) subscription users. This value is used when creating new postpaid users.",
      "description_i18n": "config.billing.default_price_per_gb.description"
    },
    {
      "key": "billing.DefaultMonthlyFee",
      "type": "string",
      "default": "0",
      "title": "Default Monthly Fee",
      "title_i18n": "config.billing.default_monthly_fee.title",
      "description": "Default monthly fee for postpaid (monthly) subscription users. This value is used as default when creating new postpaid users.",
      "description_i18n": "config.billing.default_monthly_fee.description"
    }
  ]
}